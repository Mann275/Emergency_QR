# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/emergencyqr

# JWT Secret
JWT_SECRET=replace_with_a_strong_secret

# Frontend URL for CORS and profile links
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173

# OTP mail (Brevo)
MAIL_USER=your_sender_email@example.com
BREVO_API_KEY=replace_with_brevo_api_key
# Optional alias if already configured with typo in hosting env
BRAVO_API_KEY=replace_with_brevo_api_key

